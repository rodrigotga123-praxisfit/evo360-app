{
  "entities": {
    "TrainerFinancialHistory": {
      "title": "Trainer Financial History",
      "description": "Monthly financial performance records for trainers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "trainerId": { "type": "string" },
        "mes": { "type": "string" },
        "faturamento": { "type": "number" },
        "alunos": { "type": "integer" },
        "ticketMedio": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "trainerId", "mes", "faturamento", "alunos", "ticketMedio", "createdAt"]
    },
    "UserAnalysis": {
      "title": "User Score Analysis",
      "description": "Historical record of user scores and profile analysis",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "aderencia": { "type": "integer" },
        "risco": { "type": "integer" },
        "prontidao": { "type": "integer" },
        "perfil": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "aderencia", "risco", "prontidao", "perfil", "createdAt"]
    },
    "TrainerStudentRelationship": {
      "title": "Trainer-Student Relationship",
      "description": "Relationship between a trainer and a student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "trainerId": { "type": "string" },
        "status": { "type": "string", "enum": ["ativo", "inativo"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "trainerId", "status", "createdAt"]
    },
    "TrainerInvite": {
      "title": "Trainer Invite",
      "description": "Record of an invite code generated by a trainer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "inviteCode": { "type": "string" },
        "plan": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "inviteCode", "plan", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "Extended user profile with fitness scores and gamification",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "role": { "type": "string", "enum": ["user", "trainer", "admin"] },
        "tipo": { "type": "string", "enum": ["aluno", "treinador", "admin"] },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "achievements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "icon": { "type": "string" },
              "unlockedAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "onboardingComplete": { "type": "boolean" },
        "currentPhase": { "type": "integer" },
        "treinadorId": { "type": "string" },
        "protocolo": { "type": "string" },
        "inviteCode": { "type": "string" },
        "status": { "type": "string", "enum": ["invited", "active", "inactive"] },
        "plan": { "type": "string", "enum": ["free", "pro", "premium"] },
        "subscriptionStatus": { "type": "string", "enum": ["active", "past_due", "canceled"] },
        "bio": { "type": "string" },
        "instagram": { "type": "string" },
        "stepGoal": { "type": "integer", "description": "Current daily step goal" },
        "consecutiveDaysMet": { "type": "integer", "description": "Number of consecutive days step goal was met" },
        "iwtPhase": { "type": "integer", "description": "Current IWT phase (1-3)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "scores": {
          "type": "object",
          "properties": {
            "adherence": { "type": "number" },
            "risk": { "type": "number" },
            "readiness": { "type": "number" },
            "evolution": { "type": "number" },
            "behavioral": { "type": "number" },
            "movement": { "type": "number", "description": "Movement Score" },
            "dimensions": {
              "type": "object",
              "properties": {
                "acao": { "type": "number" },
                "consistencia": { "type": "number" },
                "emocional": { "type": "number" },
                "cognitivo": { "type": "number" },
                "motivacao": { "type": "number" },
                "treino": { "type": "number" }
              }
            }
          }
        }
      },
      "required": ["uid", "fullName", "email", "role", "xp", "level"]
    },
    "DailyActivity": {
      "title": "Daily Activity Log",
      "description": "Daily tracking of steps, IWT, and calories",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "steps": { "type": "integer" },
        "stepGoal": { "type": "integer" },
        "iwtMinutes": { "type": "integer" },
        "iwtPhase": { "type": "integer" },
        "calories": { "type": "number" },
        "movementScore": { "type": "number" },
        "workoutCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "steps", "stepGoal", "createdAt"]
    },
    "CommunityPost": {
      "title": "Community Post",
      "description": "Activity feed post with social features",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "type": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "comments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "text": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WeeklyCheckIn": {
      "title": "Weekly Check-in",
      "description": "Weekly status update with AI feedback",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "feeling": { "type": "string", "enum": ["excelente", "bom", "regular", "cansado", "exaurido"] },
        "energy": { "type": "integer" },
        "pain": { "type": "integer" },
        "motivation": { "type": "integer" },
        "sleepQuality": { "type": "integer" },
        "stressLevel": { "type": "integer" },
        "notes": { "type": "string" },
        "aiFeedback": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AppNotification": {
      "title": "App Notification",
      "description": "In-app notifications for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["workout_reminder", "absence_alert", "incentive", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WorkoutFeedback": {
      "title": "Workout Session Feedback",
      "description": "Feedback collected after a workout session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "workoutName": { "type": "string" },
        "exertion": { "type": "integer", "description": "RPE scale 1-10" },
        "painPoints": { "type": "string" },
        "duration": { "type": "integer", "description": "Duration in seconds" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "workoutName", "exertion", "createdAt"]
    },
    "WorkoutLog": {
      "title": "Workout Performance Log",
      "description": "Detailed log of a workout session including sets, reps, and load",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "workoutName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "exercises": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "exerciseName": { "type": "string" },
              "sets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "carga": { "type": "number" },
                    "reps": { "type": "integer" },
                    "sensacao": { "type": "string" }
                  }
                }
              },
              "completed": { "type": "boolean" },
              "completedAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "totalDuration": { "type": "integer" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "workoutName", "date", "exercises", "completed", "createdAt"]
    },
    "WeeklyPlan": {
      "title": "Weekly Training Plan",
      "description": "A plan containing workouts for each day of the week",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "days": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "days", "createdAt"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "Fitness challenge for students",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "objective": { "type": "string" },
        "duration": { "type": "string" },
        "status": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "trainerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TrainerWorkout": {
      "title": "Trainer Workout Template",
      "description": "Workout template created by a trainer",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "days": { "type": "object" },
        "trainerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TrainerObservation": {
      "title": "Trainer Observation",
      "description": "Observation or note about a student by a trainer",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "trainerId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TrainerFinance": {
      "title": "Trainer Finance Data",
      "description": "Financial data for trainer pricing and cost analysis",
      "type": "object",
      "properties": {
        "trainerId": { "type": "string" },
        "fixedCosts": {
          "type": "object",
          "properties": {
            "rent": { "type": "number" },
            "electricity": { "type": "number" },
            "water": { "type": "number" },
            "internet": { "type": "number" },
            "transport": { "type": "number" },
            "others": { "type": "number" }
          }
        },
        "availableTime": {
          "type": "object",
          "properties": {
            "hoursPerWeek": { "type": "number" }
          }
        },
        "capacity": {
          "type": "object",
          "properties": {
            "maxConsultingStudents": { "type": "number" },
            "maxPersonalSessions": { "type": "number" }
          }
        },
        "currentPricing": {
          "type": "object",
          "properties": {
            "personalSession": { "type": "number" },
            "consultingMonth": { "type": "number" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trainerId", "fixedCosts", "availableTime", "capacity", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Community activity feed"
    },
    "/weekly_checkins/{checkinId}": {
      "schema": "WeeklyCheckIn",
      "description": "Weekly check-ins"
    },
    "/notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "In-app notifications"
    },
    "/assessments/{assessmentId}": {
      "schema": "PhysicalAssessment",
      "description": "Physical measurements"
    },
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Training programs"
    },
    "/workout_feedback/{feedbackId}": {
      "schema": "WorkoutFeedback",
      "description": "Post-workout feedback"
    },
    "/workout_logs/{logId}": {
      "schema": "WorkoutLog",
      "description": "Detailed workout logs"
    },
    "/weekly_plans/{planId}": {
      "schema": "WeeklyPlan",
      "description": "Weekly training plans"
    },
    "/daily_activities/{activityId}": {
      "schema": "DailyActivity",
      "description": "Daily activity tracking"
    },
    "/trainer_workouts/{workoutId}": {
      "schema": "TrainerWorkout",
      "description": "Trainer workout templates"
    },
    "/challenges/{challengeId}": {
      "schema": "Challenge",
      "description": "Fitness challenges"
    },
    "/trainer_observations/{observationId}": {
      "schema": "TrainerObservation",
      "description": "Trainer observations"
    },
    "/trainer_finance/{financeId}": {
      "schema": "TrainerFinance",
      "description": "Trainer financial data"
    },
    "/invites/{inviteId}": {
      "schema": "TrainerInvite",
      "description": "Trainer invite codes"
    },
    "/trainer_student_relationships/{id}": {
      "schema": "TrainerStudentRelationship",
      "description": "Trainer-student relationships"
    },
    "/user_analyses/{id}": {
      "schema": "UserAnalysis",
      "description": "User score and profile analysis history"
    },
    "/trainer_financial_history/{id}": {
      "schema": "TrainerFinancialHistory",
      "description": "Trainer monthly financial history"
    }
  }
}
